# API 基础 URL (生产环境请设置为你的后端API地址)
VITE_APP_API_URL=http://localhost:3000/api

# 可选：单独指定后端源站域名（用于拼接 /uploads、/api/... 等资源地址）
# VITE_APP_API_ORIGIN=http://localhost:3000

# 可选：如果生产环境明确要走独立 API 域名，而不是当前站点的 /api，再开启它
# VITE_ALLOW_CROSS_ORIGIN_API=true

# 可选：单独指定静态资源基地址（例如 CDN 或对象存储前缀）
# VITE_ASSET_BASE_URL=http://localhost:3000/uploads

# 应用信息
VITE_APP_TITLE=Vorest's Personal Website
VITE_APP_VERSION=1.0.0

# 文件上传限制
VITE_APP_FILE_UPLOAD_MAX_SIZE=50MB
VITE_APP_IMAGE_UPLOAD_MAX_SIZE=10MB

# 开发模式
VITE_APP_ENV=development
